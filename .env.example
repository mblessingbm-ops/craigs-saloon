# Copy to .env.local and fill in from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose to the browser). Needed for the WhatsApp webhook / admin scripts.
# Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Business (Meta Cloud API) — see docs/whatsapp-setup.md
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=   # Meta App → Settings → Basic → App Secret (verifies inbound webhook signatures)

# Scheduled reminders (Vercel Cron hits /api/cron/reminders hourly)
CRON_SECRET=
